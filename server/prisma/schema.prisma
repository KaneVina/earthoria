generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── USER ───
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String?
  googleId  String?  @unique
  name      String
  phone     String?
  avatar    String?
  role      Role     @default(CUSTOMER)
  isActive  Boolean  @default(true)

  // Mã định danh người dùng: ETR-Role-MMDDYY-SEQ-rand (vd: ETRC062926001ak)
  userCode  String?  @unique

  resetOtpHash      String?
  resetOtpExpires   DateTime?
  resetOtpAttempts  Int       @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  addresses Address[]
  orders    Order[]
  cart      Cart?
  reviews   Review[]
  wishlist  Wishlist[]
}

// Bảng đếm số thứ tự theo ngày để sinh userCode
model UserCodeSeq {
  date  String @id   // format: "YYYYMMDD"
  seq   Int    @default(0)
}

enum Role {
  CUSTOMER
  STAFF
  ADMIN
}

// ─── PENDING USER (chờ xác thực OTP khi đăng ký) ───
model PendingUser {
  id          String   @id @default(uuid())
  email       String   @unique
  name        String
  password    String
  phone       String?
  otpHash     String
  otpExpires  DateTime
  otpAttempts Int      @default(0)
  createdAt   DateTime @default(now())
}

// ─── ADDRESS ───
model Address {
  id        String  @id @default(uuid())
  userId    String
  fullName  String
  phone     String
  province  String
  district  String
  ward      String
  street    String
  isDefault Boolean @default(false)
  lat       Float?
  lng       Float?

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]
}

// ─── CATEGORY ───
model Category {
  id          String  @id @default(uuid())
  name        String
  slug        String  @unique
  description String?
  image       String?
  isActive    Boolean @default(true)

  books Book[]
}

// ─── BOOK ───
model Book {
  id            String   @id @default(uuid())
  title         String
  slug          String   @unique
  description   String?
  price         Float
  salePrice     Float?
  dealerPrice   Float?
  stock         Int      @default(0)
  sold          Int      @default(0)
  ageMin        Int?
  ageMax        Int?
  language      String   @default("VI")
  pages         Int?
  publisher     String?
  publishYear   Int?
  dimensions    String?  // chuỗi tự do, vd "21 x 28 x 1.2 cm"
  weightGrams   Int?
  coverType     String?  // vd "Cứng, chống nước"
  paperType     String?  // vd "FSC Certified 150gsm"
  coverImage    String?
  images        String[]
  arModelUrl    String?
  arPreviewUrls String[]
  hasAR         Boolean  @default(true)
  hasAI         Boolean  @default(true)
  has3DAudio    Boolean  @default(false)
  isActive      Boolean  @default(true)
  isFeatured    Boolean  @default(false)
  categoryId    String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  category   Category     @relation(fields: [categoryId], references: [id])
  cartItems  CartItem[]
  orderItems OrderItem[]
  reviews    Review[]
  wishlist   Wishlist[]
  arCodes    ArCode[]
  authors    BookAuthor[]

  @@index([categoryId])
  @@index([language])
  @@index([isActive])
}

// ─── AUTHOR ───
// 1 sách có thể có nhiều tác giả, 1 tác giả có thể viết nhiều sách -> quan hệ n-n qua BookAuthor
model Author {
  id    String       @id @default(uuid())
  name  String       @unique
  books BookAuthor[]
}

// Bảng nối Book <-> Author, có `order` để giữ đúng thứ tự tác giả khi hiển thị
// (vd: "Tác giả chính, Đồng tác giả" thay vì bị xáo trộn)
model BookAuthor {
  bookId   String
  authorId String
  order    Int    @default(0)

  book   Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)
  author Author @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@id([bookId, authorId])
  @@index([authorId])
}

// ─── AR CODE ───
// Mỗi sách có thể có nhiều mã AR (vd: sách về động vật -> mã riêng cho
// con voi, con heo...). Mỗi mã gắn với 1 model 3D và được in thành 1 QR
// cố định trong sách giấy, nên `code` không bao giờ được đổi sau khi in.
//
// BẢO MẬT: `code` PHẢI là chuỗi ngẫu nhiên sinh bằng CSPRNG (crypto.randomBytes),
// KHÔNG được là số đếm tăng dần hay encode/decode được (vd hashids), vì đó
// chỉ là obfuscation hai chiều, không chống được việc đoán mã giữa các sách.
// `code` là chìa khóa tra cứu duy nhất — `slug` trong URL chỉ để hiển thị
// tên sách đẹp mắt, KHÔNG được dùng để xác thực hay tra cứu.
model ArCode {
  id        String   @id @default(uuid())
  code      String   @unique // chuỗi ngẫu nhiên 32 ký tự, vd từ crypto.randomBytes(24).toString('base64url')
  label     String   // tên gợi nhớ cho admin, vd "Con voi", "Con heo"
  modelUrl  String   // đường dẫn file .glb hiện tại — đổi được bất cứ lúc nào mà QR không đổi
  posterUrl String?  // ảnh preview hiển thị khi model đang tải (tuỳ chọn)
  bookId    String
  isActive  Boolean  @default(true) // dùng để thu hồi mã mà không xoá, tránh lộ lịch sử
  scanCount Int      @default(0)    // đếm số lượt quét, hữu ích để theo dõi mã có bị lộ/lạm dụng không
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([bookId])
}

// ─── CART ───
model Cart {
  id        String   @id @default(uuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]
}

model CartItem {
  id       String @id @default(uuid())
  cartId   String
  bookId   String
  quantity Int    @default(1)

  cart Cart @relation(fields: [cartId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id])
}

// ─── ORDER ───
model Order {
  id              String        @id @default(uuid())
  userId          String
  addressId       String
  status          OrderStatus   @default(PENDING)
  paymentMethod   PaymentMethod
  paymentStatus   PaymentStatus @default(UNPAID)
  subtotal        Float
  shippingFee     Float         @default(0)
  discount        Float         @default(0)
  total           Float
  note            String?
  stripePaymentId String?
  couponCode      String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user    User        @relation(fields: [userId], references: [id])
  address Address     @relation(fields: [addressId], references: [id])
  items   OrderItem[]
}

model OrderItem {
  id       String @id @default(uuid())
  orderId  String
  bookId   String
  quantity Int
  price    Float

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  book  Book  @relation(fields: [bookId], references: [id])
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPING
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  COD
  STRIPE
  VNPAY
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}

// ─── REVIEW ───
model Review {
  id        String   @id @default(uuid())
  userId    String
  bookId    String
  rating    Int
  title     String?
  content   String?
  isVisible Boolean  @default(true)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)
}

// ─── WISHLIST ───
model Wishlist {
  id        String   @id @default(uuid())
  userId    String
  bookId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
}

// ─── COUPON ───
model Coupon {
  id          String     @id @default(uuid())
  code        String     @unique
  type        CouponType
  value       Float
  minOrder    Float      @default(0)
  maxDiscount Float?
  usageLimit  Int?
  usedCount   Int        @default(0)
  isActive    Boolean    @default(true)
  expiresAt   DateTime?
  createdAt   DateTime   @default(now())
}

enum CouponType {
  PERCENTAGE
  FIXED
}
